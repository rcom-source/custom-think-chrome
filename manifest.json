{
  "manifest_version": 3,
  "name": "Claude Custom Think",
  "version": "1.0.0",
  "description": "Replace Claude's thinking indicator with fun themed words",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://claude.ai/*", "https://claude.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://claude.com/*"],
      "js": ["content/content.js"],
      "css": ["styles/override.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
